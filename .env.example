APP_NAME=Tinnova Vehicle API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

SECRET_KEY=tinnova-vehicle-api-super-secret-key-2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=tinnova_vehicle_db
POSTGRES_USER=tinnova
POSTGRES_PASSWORD=tinnova

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL_USD_BRL=300

EXCHANGE_RATE_PRIMARY_URL=https://economia.awesomeapi.com.br/json/last/USD-BRL
EXCHANGE_RATE_FALLBACK_URL=https://api.frankfurter.app/latest?from=USD&to=BRL
EXCHANGE_RATE_TIMEOUT_SECONDS=5

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!

SEED_USER_USERNAME=user
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=User123!
